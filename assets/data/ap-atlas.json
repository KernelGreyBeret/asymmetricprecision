    },
    {
      "id": "principle-evidence",
      "label": "Evidence Over Assumption",
      "type": "principle",
      "domain": "Decision Making",
      "summary": "Good decisions come from understanding reality as it is. The system is usually telling the truth."
    },
    {
      "id": "principle-outcomes",
      "label": "Design for Outcomes",
      "type": "principle",
      "domain": "Operational Design",
      "summary": "Activities matter only insofar as they create meaningful outcomes. Motion is not progress."
    },
    {
      "id": "principle-practical",
      "label": "Practical Over Theoretical",
      "type": "principle",
      "domain": "Operational Design",
      "summary": "Frameworks should improve real organizations, not just explain them. Ideas should survive contact with reality."
    },
    {
      "id": "principle-relationships",
